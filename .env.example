APP_NAME="Q32 Hub"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=q32hub
DB_USERNAME=
DB_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=redis
QUEUE_CONNECTION=redis

# Google Calendar integration (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Anthropic API for AI Chat (optional)
ANTHROPIC_API_KEY=

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NAME="Q32 Hub"
