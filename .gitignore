# Dependencies
/node_modules
/vendor

# Build output
/public/build
/public/hot
/public/storage
/dist

# PWA runtime files (generated by vite-plugin-pwa + promoteServiceWorkerToRoot)
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/workbox-*.js.map

# Environment
.env
.env.backup
.env.production
.env.bak*
*.env.bak
.env.local
.env.*.local

# Laravel
/storage/*.key
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*.log
/bootstrap/cache/*

# Runtime-uploaded content (user images shouldn't be in the repo)
/storage/app/public/recipes/
/storage/app/public/restaurants/
/storage/app/public/avatars/

# Dev SQLite databases
/database/*.sqlite
/database/*.sqlite-journal

# Dev artifacts / temp files
.playwright-mcp/
cookies.txt
gaal.yaml
php-*cacert.pem

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Testing
.phpunit.result.cache
/coverage
/storage/framework/testing/

# Quality tools
.eslintcache

# Claude Code (ignore all except slash commands)
.claude/*
!.claude/commands/

# Personal/local CLAUDE context (not for the public repo)
CLAUDE.local.md

# Session captures
*-session-capture.md

# Plugin-generated skills
.github/skills/

# Misc
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
test-results/
