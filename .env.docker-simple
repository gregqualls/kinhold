# Kinhold — Zero-Dependency Configuration
# This config runs Kinhold with SQLite and file-based caching.
# No PostgreSQL, Redis, or external services required.
# Copy this to .env before running: cp .env.docker-simple .env

APP_NAME=Kinhold
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# APP_KEY is auto-generated on first boot — do not set here

LOG_CHANNEL=single
LOG_LEVEL=debug

# Database — SQLite (zero config, data persists in /data volume)
DB_CONNECTION=sqlite
DB_DATABASE=/data/kinhold.sqlite

# Cache & Queue — file-based (no Redis needed)
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Frontend
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Kinhold

# ---------------------------------------------------------------------------
# Optional integrations — uncomment and configure to enable
# ---------------------------------------------------------------------------

