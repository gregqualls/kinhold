{
    "name": "kinhold/laravel-backend",
    "description": "Kinhold - Family Hub Web Application Backend",
    "type": "project",
    "license": "Elastic-2.0",
    "require": {
        "php": "^8.2",
        "google/apiclient": "^2.0",
        "guzzlehttp/guzzle": "^7.0",
        "laravel/framework": "^11.0",
        "laravel/mcp": "^0.6.4",
        "laravel/passport": "^13.7.1",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.25",
        "league/flysystem-aws-s3-v3": "^3.0",
        "resend/resend-laravel": "^1.3",
        "sabre/vobject": "^4.5"
    },
    "require-dev": {
        "fakerphp/faker": "^1.0",
        "larastan/larastan": "^2.0",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-install-cmd": [
            "@php artisan optimize:clear",
            "git config core.hooksPath hooks 2>/dev/null || true"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin-laravel": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
